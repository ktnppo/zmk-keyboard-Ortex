#include <dt-bindings/zmk/matrix_transform.h>
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <physical_layouts.dtsi>

// 1. IOエクスパンダ(MCP23017)の定義
&i2c0 {
    status = "okay";
    /* XIAO nRF52840のデフォルトI2Cピン（P0.04/P0.05）を使用 */

    mcp23017: mcp23017@20 {
        compatible = "microchip,mcp23017";
        status = "okay";
        reg = <0x20>; // A0, A1, A2がすべてGNDなのでアドレスは0x20
        gpio-controller;
        #gpio-cells = <2>;

        /* 割り込みピンの設定 (R_I2C_INT -> XIAOのP1.11 / D6ピン) */
        int-gpios = <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };
};

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "default_layout";

        kscan = <&kscan0>;
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0> //1行目
            , <&key_physical_attrs 100 100  100    0       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400    0       0     0     0>
            , <&key_physical_attrs 100 100  800    0       0     0     0>
            , <&key_physical_attrs 100 100  900    0       0     0     0>
            , <&key_physical_attrs 100 100 1000    0       0     0     0>
            , <&key_physical_attrs 100 100 1100    0       0     0     0>
            , <&key_physical_attrs 100 100 1200    0       0     0     0>

            , <&key_physical_attrs 100 100    0  100       0     0     0> //2行目
            , <&key_physical_attrs 100 100  100  100       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  100       0     0     0>
            , <&key_physical_attrs 100 100  800  100       0     0     0>
            , <&key_physical_attrs 100 100  900  100       0     0     0>
            , <&key_physical_attrs 100 100 1000  100       0     0     0>
            , <&key_physical_attrs 100 100 1100  100       0     0     0>
            , <&key_physical_attrs 100 100 1200  100       0     0     0>

            , <&key_physical_attrs 100 100    0  200       0     0     0> //3行目
            , <&key_physical_attrs 100 100  100  200       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  200       0     0     0>
            , <&key_physical_attrs 100 100  500  200       0     0     0>
            , <&key_physical_attrs 100 100  700  200       0     0     0>
            , <&key_physical_attrs 100 100  800  200       0     0     0>
            , <&key_physical_attrs 100 100  900  200       0     0     0>
            , <&key_physical_attrs 100 100 1000  200       0     0     0>
            , <&key_physical_attrs 100 100 1100  200       0     0     0>
            , <&key_physical_attrs 100 100 1200  200       0     0     0>

            , <&key_physical_attrs 100 100    0  300       0     0     0> //4行目
            , <&key_physical_attrs 100 100  100  300       0     0     0>
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 100 100  400  300       0     0     0>
            , <&key_physical_attrs 100 100  500  300       0     0     0>
            , <&key_physical_attrs 100 100  700  300       0     0     0>
            , <&key_physical_attrs 100 100  800  300       0     0     0>
            , <&key_physical_attrs 100 100 1100  300       0     0     0>
            , <&key_physical_attrs 100 100 1200  300       0     0     0>

            , <&key_physical_attrs 100 100  400  400       0     0     0>　//マウススイッチ
            , <&key_physical_attrs 100 100  500  400       0     0     0>
            , <&key_physical_attrs 100 100  700  400       0     0     0>
            , <&key_physical_attrs 100 100  800  400       0     0     0>

            , <&key_physical_attrs 100 100    0  600       0     0     0> //ジョイスティック（拡張モジュール：左）
            , <&key_physical_attrs 100 100  100  500       0     0     0>
            , <&key_physical_attrs 100 100  100  600       0     0     0>
            , <&key_physical_attrs 100 100  100  700       0     0     0>
            , <&key_physical_attrs 100 100  200  600       0     0     0>
            , <&key_physical_attrs 100 100  300  600       0     0     0> //ジョイスティック（基本モジュール：左）
            , <&key_physical_attrs 100 100  400  500       0     0     0>
            , <&key_physical_attrs 100 100  400  600       0     0     0>
            , <&key_physical_attrs 100 100  400  700       0     0     0>
            , <&key_physical_attrs 100 100  500  600       0     0     0>

            , <&key_physical_attrs 100 100  700  600       0     0     0> //ジョイスティック（基本モジュール：右）
            , <&key_physical_attrs 100 100  800  500       0     0     0>
            , <&key_physical_attrs 100 100  800  600       0     0     0>
            , <&key_physical_attrs 100 100  800  700       0     0     0>
            , <&key_physical_attrs 100 100  900  500       0     0     0>
            , <&key_physical_attrs 100 100 1000  600       0     0     0> //ジョイスティック（拡張モジュール：右）
            , <&key_physical_attrs 100 100 1100  500       0     0     0>
            , <&key_physical_attrs 100 100 1100  600       0     0     0>
            , <&key_physical_attrs 100 100 1100  700       0     0     0>
            , <&key_physical_attrs 100 100 1200  500       0     0     0>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;               
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)                      RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)                      RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)     RC(3,11) RC(3,10)                 RC(3,7) RC(3,6)
                                            RC(0,5) RC(1,5)     RC(1,11) RC(0,11)
                    RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)     RC(4,11) RC(4,10) RC(4,9) RC(4,8) RC(4,7)
                    RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)     RC(5,11) RC(5,10) RC(5,9) RC(5,8) RC(5,7)
        >;
    };
    
// 2. 既存のkscan0にエクスパンダ経由のマトリクスピンアサインを統合
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        /* ROW（行）の定義：GPB0〜GPB4 ＝ 8〜12番ピンを使用 */
        row-gpios
            = <&mcp23017  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB0 (ROW0)
            , <&mcp23017  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB1 (ROW1)
            , <&mcp23017 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB2 (ROW2)
            , <&mcp23017 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB3 (ROW3)
            , <&mcp23017 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB4 (ROW4)
            , <&mcp23017 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // GPB5 (ROW5)
            ;

        /* COL（列）の定義：GPA0〜GPA5 ＝ 0〜5番ピンを使用 */
        col-gpios
            = <&mcp23017  0 GPIO_ACTIVE_HIGH> // GPA0 (COL0)
            , <&mcp23017  1 GPIO_ACTIVE_HIGH> // GPA1 (COL1)
            , <&mcp23017  2 GPIO_ACTIVE_HIGH> // GPA2 (COL2)
            , <&mcp23017  3 GPIO_ACTIVE_HIGH> // GPA3 (COL3)
            , <&mcp23017  4 GPIO_ACTIVE_HIGH> // GPA4 (COL4)
            , <&mcp23017  5 GPIO_ACTIVE_HIGH> // GPA5 (COL5)
            ;
    };

    //right hand trackball
    trackball_central_listener: trackball_central_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        input-processors = 
            <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>;         //Y軸反転
            //<&zip_xy_transform INPUT_TRANSFORM_XY_SWAP>,        //X軸とY軸の入れ替え
            //<&zip_xy_transform INPUT_TRANSFORM_X_INVERT>,       //X軸反転
            //<&zip_temp_layer 5 500>;                              //オートマウスレイヤーの選択
    };

    left_encoder_1: encoder_left_1 {
        compatible = "alps,ec11";
        a-gpios = <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&xiao_d 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    left_encoder_2: encoder_left_2 {
        compatible = "alps,ec11";
        a-gpios = <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    left_encoder_3: encoder_left_3 {
        compatible = "alps,ec11";
        a-gpios = <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    right_encoder: encoder_right {
         compatible = "alps,ec11";
        a-gpios = <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder_1 &left_encoder_2 &left_encoder_3 &right_encoder>;
        triggers-per-rotation = <10>;
    };

};
